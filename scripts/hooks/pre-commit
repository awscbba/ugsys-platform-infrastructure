#!/usr/bin/env bash
# pre-commit hook — lint check on staged CDK stack files
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "🔍 Running pre-commit checks..."
echo ""

# ── 1. Block commits to main ─────────────────────────────────────────────────
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [[ "$BRANCH" == "main" ]]; then
  echo -e "${RED}✗ Direct commits to 'main' are not allowed.${NC}"
  echo "  Create a feature branch: git checkout -b feature/your-feature"
  exit 1
fi

# ── 2. Check if any infra files are staged ───────────────────────────────────
STAGED=$(git diff --cached --name-only)
if ! echo "$STAGED" | grep -q "^infra/"; then
  echo -e "${GREEN}✓ No infra changes staged — skipping lint.${NC}"
  echo ""
  exit 0
fi

FAILED=0

echo -e "${YELLOW}── Ruff lint (stacks/) ──${NC}"
if uv tool run ruff check infra/stacks/ --quiet 2>&1; then
  echo -e "  ${GREEN}✓ ruff lint${NC}"
else
  echo -e "  ${RED}✗ ruff lint failed — run: just lint${NC}"
  FAILED=1
fi

echo -e "${YELLOW}── Ruff format check ──${NC}"
if uv tool run ruff format --check infra/stacks/ --quiet 2>&1; then
  echo -e "  ${GREEN}✓ ruff format${NC}"
else
  echo -e "  ${RED}✗ ruff format failed — run: just format${NC}"
  FAILED=1
fi

echo ""

if [ $FAILED -ne 0 ]; then
  echo -e "${RED}✗ Pre-commit checks failed.${NC}"
  exit 1
fi

echo -e "${GREEN}✓ All pre-commit checks passed.${NC}"
echo ""
exit 0
