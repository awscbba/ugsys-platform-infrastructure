#!/usr/bin/env bash
# pre-commit hook: block direct commits to main, lint/format/synth staged infra files

set -euo pipefail

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-commit checks"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ "$BRANCH" = "main" ]; then
    echo "✗ Direct commits to 'main' are not allowed."
    echo "  Please create a feature branch and open a pull request."
    exit 1
fi

echo "  branch : $BRANCH"
echo ""

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -n "$STAGED_PY" ]; then
    echo "── Staged Python files ──────────────────────────────"
    for f in $STAGED_PY; do echo "   $f"; done
    echo ""

    echo "▶ ruff check ..."
    # shellcheck disable=SC2086
    if ! uv run ruff check $STAGED_PY; then
        echo "✗ ruff check failed. Run 'just lint' to see all issues."
        exit 1
    fi
    echo "✓ ruff check passed"
    echo ""

    echo "▶ ruff format --check ..."
    # shellcheck disable=SC2086
    if ! uv run ruff format --check --diff $STAGED_PY; then
        echo "✗ ruff format check failed. Run 'just format' to fix."
        exit 1
    fi
    echo "✓ ruff format passed"
    echo ""

    # Only run CDK synth if infra/ files are staged
    STAGED_INFRA=$(echo "$STAGED_PY" | grep '^infra/' || true)
    if [ -n "$STAGED_INFRA" ]; then
        echo "▶ cdk synth (validates all stacks) ..."
        if ! JSII_SILENCE_WARNING_UNTESTED_NODE_VERSION=1 uv run cdk synth --app "python infra/app.py" --quiet; then
            echo "✗ CDK synth failed — fix stack errors before committing."
            exit 1
        fi
        echo "✓ CDK synth passed"
        echo ""
    fi
else
    echo "  (no staged Python files)"
    echo ""
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✓ pre-commit checks passed"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
exit 0
